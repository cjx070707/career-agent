{
  "$defs": {
    "ChatPlan": {
      "properties": {
        "follow_up_question": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Follow Up Question"
        },
        "missing_context": {
          "items": {
            "type": "string"
          },
          "title": "Missing Context",
          "type": "array"
        },
        "needs_more_context": {
          "default": false,
          "title": "Needs More Context",
          "type": "boolean"
        },
        "planner_source": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Where the plan came from: router, model, or fallback",
          "title": "Planner Source"
        },
        "reason": {
          "description": "Human-readable routing rationale",
          "title": "Reason",
          "type": "string"
        },
        "steps": {
          "items": {
            "type": "string"
          },
          "title": "Steps",
          "type": "array"
        },
        "task_type": {
          "description": "Machine-readable task label",
          "title": "Task Type",
          "type": "string"
        }
      },
      "required": [
        "task_type",
        "reason"
      ],
      "title": "ChatPlan",
      "type": "object"
    },
    "ChatSource": {
      "properties": {
        "company": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Hiring organization name",
          "title": "Company"
        },
        "location": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Job location",
          "title": "Location"
        },
        "posted_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Posting date",
          "title": "Posted At"
        },
        "snippet": {
          "description": "Short grounded evidence text",
          "title": "Snippet",
          "type": "string"
        },
        "title": {
          "description": "Short source title for display",
          "title": "Title",
          "type": "string"
        },
        "type": {
          "description": "Evidence source category",
          "title": "Type",
          "type": "string"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Source link",
          "title": "Url"
        },
        "work_type": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Job type such as intern or graduate",
          "title": "Work Type"
        }
      },
      "required": [
        "type",
        "title",
        "snippet"
      ],
      "title": "ChatSource",
      "type": "object"
    },
    "LLMTrace": {
      "properties": {
        "generate_source": {
          "default": "not_used",
          "title": "Generate Source",
          "type": "string"
        },
        "job_search_summary_source": {
          "default": "not_used",
          "title": "Job Search Summary Source",
          "type": "string"
        },
        "planner_source": {
          "default": "not_used",
          "title": "Planner Source",
          "type": "string"
        }
      },
      "title": "LLMTrace",
      "type": "object"
    }
  },
  "properties": {
    "answer": {
      "title": "Answer",
      "type": "string"
    },
    "contract_version": {
      "const": "chat.v1",
      "default": "chat.v1",
      "description": "Stable /chat response contract version",
      "title": "Contract Version",
      "type": "string"
    },
    "llm_trace": {
      "$ref": "#/$defs/LLMTrace"
    },
    "memory_used": {
      "default": false,
      "title": "Memory Used",
      "type": "boolean"
    },
    "plan": {
      "anyOf": [
        {
          "$ref": "#/$defs/ChatPlan"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "sources": {
      "items": {
        "$ref": "#/$defs/ChatSource"
      },
      "title": "Sources",
      "type": "array"
    },
    "tool_trace": {
      "items": {
        "type": "string"
      },
      "title": "Tool Trace",
      "type": "array"
    },
    "tool_used": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Tool Used"
    }
  },
  "required": [
    "answer"
  ],
  "title": "ChatResponse",
  "type": "object"
}
